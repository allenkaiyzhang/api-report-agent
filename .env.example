# ── Secrets for Market Report Agent ────────────────────────────
# Copy to .env and fill in your values.
# NEVER commit .env to the repository.

# API auth token for the FastAPI service
API_KEY=replace-with-strong-token
API_TOKEN=replace-with-strong-token

# ── Market Data Provider ───────────────────────────────────────
# Options: mock, longbridge_mcp
# Production MUST be longbridge_mcp (mock is only for testing)
MARKET_DATA_PROVIDER=longbridge_mcp

# Longbridge MCP endpoint
#   Global: https://mcp.longbridge.com
#   Mainland China: https://mcp.longbridge.cn
LONGBRIDGE_MCP_URL=https://mcp.longbridge.com

# Longbridge MCP OAuth 2.1 token
# Obtain from: https://open.longbridge.com/docs/mcp
LONGBRIDGE_MCP_OAUTH_TOKEN=

# Application environment: production, staging, test
APP_ENV=production

# ── SMTP (email notifications) ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FORCE_IPV4=true
SMTP_RETRIES=3
SMTP_RETRY_SECONDS=5
EMAIL_FROM=
EMAIL_TO=
EMAIL_SUBJECT_PREFIX=[Market Report]

# ── Webhook (optional) ─────────────────────────────────────────
WEBHOOK_URL=
WEBHOOK_SECRET=

# ── AI provider keys (optional, for AI-enhanced reports) ──────
DEEPSEEK_API_KEY=
OPENAI_API_KEY=replace-me-if-needed
GEMINI_API_KEY=

# ── Security ───────────────────────────────────────────────────
# Account-read tools are disabled by default.
# Set to "true" only if you need to query positions/orders.
ACCOUNT_READ_ENABLED=false
# Trading tools are ALWAYS blocked in code — cannot be enabled.
